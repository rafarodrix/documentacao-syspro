{
  "name": "dosc-syspro-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/features/*/*",
    "tools/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@dosc-syspro/web",
    "lint": "turbo run lint",
    "start": "npm run start -w @dosc-syspro/web",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:api": "dotenv -e apps/api/.env -- npm run dev -w @dosc-syspro/app-api",
    "start:api": "dotenv -e apps/api/.env -- npm run start -w @dosc-syspro/app-api",
    "dev:mobile": "npm run dev -w @dosc-syspro/app-mobile",
    "start:mobile": "npm run start -w @dosc-syspro/app-mobile",
    "test:web": "npm run test -w @dosc-syspro/web",
    "test:api": "npm run test -w @dosc-syspro/app-api",
    "test:packages": "npm run test -w @dosc-syspro/remote-domain",
    "test:authz": "npm run test:authz -w @dosc-syspro/web",
    "test:tickets": "npm run test:tickets -w @dosc-syspro/web",
    "test:e2e": "npm run test:e2e -w @dosc-syspro/web",
    "test:e2e:install": "npm run test:e2e:install -w @dosc-syspro/web",
    "test:e2e:headed": "npm run test:e2e:headed -w @dosc-syspro/web",
    "test:e2e:ui": "npm run test:e2e:ui -w @dosc-syspro/web",
    "lint:remote": "npm run lint:remote -w @dosc-syspro/web",
    "lint:ds": "bash adoption/audit.sh && npm run lint -w @dosc-syspro/web",
    "lint:ds:fix": "bash adoption/audit.sh",
    "typecheck:contracts": "npm run typecheck -w @dosc-syspro/contracts",
    "db:generate": "npm run db:generate -w @dosc-syspro/database",
    "db:validate": "npm run db:validate -w @dosc-syspro/database",
    "db:migrate": "npm run db:migrate -w @dosc-syspro/database",
    "db:deploy": "npm run db:deploy -w @dosc-syspro/database",
    "db:permissions:audit-legacy": "npm run db:permissions:audit-legacy -w @dosc-syspro/database",
    "db:permissions:sanitize-legacy": "npm run db:permissions:sanitize-legacy -w @dosc-syspro/database",
    "db:seed:companies": "npm run db:seed:companies -w @dosc-syspro/database",
    "db:seed:remote": "npm run db:seed:remote -w @dosc-syspro/database",
    "docs:check": "npm run docs:check -w @dosc-syspro/web",
    "tickets:normalize-history": "node scripts/normalize-ticket-history.mjs",
    "check:utf8": "node scripts/check-utf8.mjs",
    "check:generated-js": "node scripts/check-generated-js.mjs",
    "check:api-deploy": "node scripts/check-api-deploy.mjs",
    "quality:duplication": "jscpd apps packages --reporters console,json,html --output reports/jscpd",
    "quality:architecture": "depcruise --config .dependency-cruiser.cjs apps packages --output-type err",
    "quality:dead-code": "knip",
    "security:dependencies": "npm audit --audit-level=high",
    "quality:quick": "npm run check:utf8 && npm run docs:check && npm run lint && npm run typecheck && npm run test && npm run quality:architecture",
    "quality:full": "npm run quality:quick && npm run quality:duplication && npm run quality:dead-code && npm run security:dependencies && npm run build",
    "postinstall": "npm run postinstall -w @dosc-syspro/web"
  },
  "devDependencies": {
    "dependency-cruiser": "^18.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint-plugin-trilink-tokens": "file:tools/eslint-plugin-trilink-tokens",
    "jscpd": "^5.0.12",
    "knip": "^6.29.0",
    "turbo": "^2.9.14"
  }
}
