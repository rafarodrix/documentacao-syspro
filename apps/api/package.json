{
  "name": "@dosc-syspro/app-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build --webpack --webpackPath webpack.config.js -p tsconfig.build.json",
    "dev": "nest start --webpack --webpackPath webpack.config.js --watch",
    "start": "nest start",
    "start:dev": "nest start --webpack --webpackPath webpack.config.js --watch",
    "start:debug": "nest start --debug --webpack --webpackPath webpack.config.js --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests --reporter=verbose",
    "test:watch": "vitest tests"
  },
  "dependencies": {
    "@dosc-syspro/api": "0.0.0",
    "@dosc-syspro/config": "0.0.0",
    "@dosc-syspro/contracts": "0.0.0",
    "@dosc-syspro/remote-domain": "0.0.0",
    "@prisma/client": "^5.22.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@types/express": "^5.0.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
