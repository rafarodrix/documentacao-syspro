{
  "name": "@dosc-syspro/app-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build --webpack --webpackPath webpack.config.js -p tsconfig.build.json",
    "dev": "nest start --webpack --webpackPath webpack.config.js --watch",
    "start": "nest start",
    "start:dev": "nest start --webpack --webpackPath webpack.config.js --watch",
    "start:debug": "nest start --debug --webpack --webpackPath webpack.config.js --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests --reporter=verbose",
    "test:watch": "vitest tests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@dosc-syspro/application": "file:../../packages/application",
    "@dosc-syspro/config": "file:../../packages/config",
    "@dosc-syspro/contracts": "file:../../packages/contracts",
    "@dosc-syspro/core": "file:../../packages/core",
    "@dosc-syspro/database": "file:../../packages/database",
    "@dosc-syspro/remote-domain": "file:../../packages/remote-domain",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "^5.22.0",
    "better-auth": "^1.3.34",
    "nodemailer": "^8.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
