# Em self-hosting, as variaveis NEXT_PUBLIC_* precisam apontar para o dominio final
# ja no build da imagem, porque o Next.js embute esses valores no bundle do navegador.
# `NEXT_PUBLIC_APP_URL`, `NEXT_PUBLIC_WEB_URL` e `NEXT_PUBLIC_SITE_URL` normalmente
# usam o mesmo dominio publico do frontend.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000/api/auth

# Usado hoje pelo Analisador XML. Nao apontar para APP_BACKEND_API_URL a menos que
# o backend do portal exponha explicitamente o endpoint /api/analyze.
NEXT_PUBLIC_API_URL=http://localhost:3333

# Base interna para chamadas server-side web -> api.
APP_BACKEND_API_URL=http://localhost:3001/api
APP_BACKEND_API=http://localhost:3001/api
APP_API_URL=http://localhost:3001/api

BETTER_AUTH_SECRET=replace-with-the-same-secret-used-by-api
INTERNAL_API_KEY=replace-with-the-same-internal-api-key-used-by-api

# Obrigatorio apenas se o fluxo de redefinicao de senha por e-mail continuar
# sendo executado pelo runtime do web.
GMAIL_USER=you@example.com
GMAIL_PASS=replace-with-app-password

# Obrigatorio se o modulo remoto do portal estiver habilitado.
REMOTE_DISCOVERY_TOKEN=replace-with-discovery-token
REMOTE_AGENT_TOKEN_TTL_DAYS=30

COMPANY_REGISTRY_PROVIDER=brasilapi
COMPANY_REGISTRY_AUTH_URL=
COMPANY_REGISTRY_LOOKUP_URL=https://brasilapi.com.br/api/cnpj/v1/{cnpj}
COMPANY_REGISTRY_CLIENT_ID=
COMPANY_REGISTRY_CLIENT_SECRET=
COMPANY_REGISTRY_SCOPE=
COMPANY_REGISTRY_AUDIENCE=
COMPANY_REGISTRY_TIMEOUT_MS=12000

REVALIDATE_TOKEN=replace-with-revalidate-token
REVALIDATE_SECRET=replace-with-revalidate-secret
# Se omitido, o check de SEFAZ usa REVALIDATE_SECRET como fallback.
SEFAZ_CHECK_SECRET=replace-with-sefaz-check-secret
