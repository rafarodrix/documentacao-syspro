{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@dosc-syspro/shared": ["../../packages/shared/src/index.ts"],
      "@dosc-syspro/shared/*": ["../../packages/shared/src/*"],
      "@dosc-syspro/ui": ["../../packages/ui/src/index.ts"],
      "@dosc-syspro/ui/*": ["../../packages/ui/src/*"],
      "@dosc-syspro/contracts": ["../../packages/contracts/src/index.ts"],
      "@dosc-syspro/contracts/agent": ["../../packages/contracts/src/agent/index.ts"],
      "@dosc-syspro/contracts/address": ["../../packages/contracts/src/shared/address.types.ts"],
      "@dosc-syspro/contracts/company": ["../../packages/contracts/src/company/index.ts"],
      "@dosc-syspro/contracts/chatwoot": ["../../packages/contracts/src/chatwoot/index.ts"],
      "@dosc-syspro/contracts/dashboard": ["../../packages/contracts/src/dashboard/index.ts"],
      "@dosc-syspro/contracts/documento": ["../../packages/contracts/src/documento/documento.types.ts"],
      "@dosc-syspro/contracts/documento-config": ["../../packages/contracts/src/documento/documento-config.types.ts"],
      "@dosc-syspro/contracts/evolution": ["../../packages/contracts/src/evolution/index.ts"],
      "@dosc-syspro/contracts/evolution-settings": ["../../packages/contracts/src/evolution/evolution-settings.types.ts"],
      "@dosc-syspro/contracts/evolution-webhook": ["../../packages/contracts/src/evolution/evolution-webhook.types.ts"],
      "@dosc-syspro/contracts/platform-notifications": ["../../packages/contracts/src/shared/platform-notifications.types.ts"],
      "@dosc-syspro/contracts/remote": ["../../packages/contracts/src/remote/index.ts"],
      "@dosc-syspro/contracts/remote-module-settings": ["../../packages/contracts/src/remote/remote-module-settings.types.ts"],
      "@dosc-syspro/contracts/settings": ["../../packages/contracts/src/settings/index.ts"],
      "@dosc-syspro/contracts/sefaz-endpoints": ["../../packages/contracts/src/sefaz/sefaz-endpoints.types.ts"],
      "@dosc-syspro/contracts/sefaz-routes": ["../../packages/contracts/src/sefaz/sefaz-routes.types.ts"],
      "@dosc-syspro/contracts/ticket": ["../../packages/contracts/src/ticket/index.ts"],
      "@dosc-syspro/contracts/user": ["../../packages/contracts/src/user/index.ts"],
      "@dosc-syspro/core": ["../../packages/core/src/index.ts"],
      "@dosc-syspro/core/*": ["../../packages/core/src/*"],
      "@dosc-syspro/database": ["../../packages/database/src/index.ts"],
      "@dosc-syspro/database/*": ["../../packages/database/src/*"],
      "@dosc-syspro/remote-infra": ["../../packages/remote-infra/src/index.ts"],
      "@dosc-syspro/remote-infra/*": ["../../packages/remote-infra/src/*"],
      "@dosc-syspro/remote-domain": ["../../packages/remote-domain/src/index.ts"],
      "@dosc-syspro/remote-domain/*": ["../../packages/remote-domain/src/*"],
      "@dosc-syspro/application": ["../../packages/application/src/index.ts"],
      "@dosc-syspro/application/*": ["../../packages/application/src/*"],
      "@dosc-syspro/config": ["../../packages/config/src/index.ts"],
      "@dosc-syspro/config/*": ["../../packages/config/src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
