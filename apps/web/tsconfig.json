{
    "extends":  "../../tsconfig.base.json",
    "compilerOptions":  {
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "src/*"
                                                  ],
                                          "@dosc-syspro/shared":  [
                                                                      "../../packages/shared/src/index.ts"
                                                                  ],
                                          "@dosc-syspro/shared/*":  [
                                                                        "../../packages/shared/src/*"
                                                                    ],
                                          "@dosc-syspro/ui":  [
                                                                  "../../packages/ui/src/index.ts"
                                                              ],
                                          "@dosc-syspro/ui/*":  [
                                                                    "../../packages/ui/src/*"
                                                                ],
                                          "@dosc-syspro/contracts":  [
                                                                         "../../packages/contracts/src/index.ts"
                                                                     ],
                                          "@dosc-syspro/contracts/*":  [
                                                                           "../../packages/contracts/src/*"
                                                                       ],
                                          "@dosc-syspro/core":  [
                                                                    "../../packages/core/src/index.ts"
                                                                ],
                                          "@dosc-syspro/core/*":  [
                                                                      "../../packages/core/src/*"
                                                                  ]
                                      },
                            "plugins":  [
                                            {
                                                "name":  "next"
                                            }
                                        ]
                        },
    "include":  [
                    "next-env.d.ts",
                    "**/*.ts",
                    "**/*.tsx",
                    ".next/types/**/*.ts"
                ],
    "exclude":  [
                    "node_modules"
                ]
}