{
    "extends":  "../../tsconfig.base.json",
    "compilerOptions":  {
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "src/*"
                                                  ],
                                          "@dosc-syspro/shared":  [
                                                                      "../../packages/shared/src/index.ts"
                                                                  ],
                                          "@dosc-syspro/shared/*":  [
                                                                        "../../packages/shared/src/*"
                                                                    ],
                                          "@dosc-syspro/ui":  [
                                                                  "../../packages/ui/src/index.ts"
                                                              ],
                                          "@dosc-syspro/ui/*":  [
                                                                    "../../packages/ui/src/*"
                                                                ]
                                      },
                            "plugins":  [
                                            {
                                                "name":  "next"
                                            }
                                        ]
                        },
    "include":  [
                    "next-env.d.ts",
                    "**/*.ts",
                    "**/*.tsx",
                    ".next/types/**/*.ts"
                ],
    "exclude":  [
                    "node_modules"
                ]
}