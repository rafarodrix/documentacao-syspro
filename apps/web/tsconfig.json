{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@dosc-syspro/shared": ["../../packages/shared/src/index.ts"],
      "@dosc-syspro/shared/*": ["../../packages/shared/src/*"],
      "@dosc-syspro/ui": ["../../packages/ui/src/index.ts"],
      "@dosc-syspro/ui/*": ["../../packages/ui/src/*"],
      "@dosc-syspro/contracts": ["../../packages/contracts/src/index.ts"],
      "@dosc-syspro/contracts/*": ["../../packages/contracts/src/*"],
      "@dosc-syspro/core": ["../../packages/core/src/index.ts"],
      "@dosc-syspro/core/*": ["../../packages/core/src/*"],
      "@dosc-syspro/database": ["../../packages/database/src/index.ts"],
      "@dosc-syspro/database/*": ["../../packages/database/src/*"],
      "@dosc-syspro/remote-domain": ["../../packages/remote-domain/src/index.ts"],
      "@dosc-syspro/remote-domain/*": ["../../packages/remote-domain/src/*"],
      "@dosc-syspro/api": ["../../packages/api/src/index.ts"],
      "@dosc-syspro/api/*": ["../../packages/api/src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
