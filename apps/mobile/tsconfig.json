{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["esnext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "allowJs": false,
    "jsx": "preserve",
    "paths": {
      "@dosc-syspro/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@dosc-syspro/contracts/*": [
        "../../packages/contracts/src/*"
      ],
      "@dosc-syspro/core": [
        "../../packages/core/src/index.ts"
      ],
      "@dosc-syspro/core/*": [
        "../../packages/core/src/*"
      ],
      "@dosc-syspro/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@dosc-syspro/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}