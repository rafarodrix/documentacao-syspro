#
# Agent Desktop / Agent Service
# -----------------------------------------------------------------------------
# Estas variaveis sao consumidas pelo apps/agent em homologacao ou deploy.
# O backend continua sendo a fonte de verdade de companyId, companyName, hostId
# e configuracao final do RustDesk via bootstrap/sync.
# Para carregar este arquivo em runtime, use o launcher:
#   powershell -ExecutionPolicy Bypass -File .\apps\agent\start-agent-from-env.ps1
#

# Endpoint do backend usado pelo agent-service.
# Alias aceito: PORTAL_API_BASE_URL
PORTAL_BASE_URL=http://localhost:3000

# Deve ser o mesmo valor de INTERNAL_API_KEY do backend.
# Alias aceito: INTERNAL_API_KEY
PORTAL_API_KEY=replace-with-internal-api-key

# Quando true, habilita chamadas do agente para a API interna do portal.
PORTAL_AGENT_API_ENABLED=true

# Estado local, versao e IPC do agente.
AGENT_IPC_ADDRESS=127.0.0.1:48721
AGENT_STATE_DIR=
AGENT_VERSION=go-agent-v1
AGENT_ENVIRONMENT=Homologacao
AGENT_LOG_LEVEL=debug

# Canal oficial de suporte exibido no tray/janela do agente.
# Alias aceito para base URL: CHATWOOT_URL
SUPPORT_CHATWOOT_BASE_URL=https://chat.example.com
SUPPORT_CHATWOOT_WEBSITE_TOKEN=replace-with-chatwoot-website-token

# Modulo remoto / RustDesk.
# Mesmo nome usado no backend.
REMOTE_ENABLED=true
REMOTE_DISCOVERY_TOKEN=replace-with-remote-discovery-token

# Este valor NAO vem de uma variavel global do backend.
# Ele representa o installToken do host remoto e deve ser emitido/vinculado por host.
REMOTE_INSTALL_TOKEN=replace-with-remote-install-token

# Pode ser uma URL HTTPS ou um caminho local/arquivo embutido no pacote.
# Preferencia enterprise: MSI.
# Homologacao inicial pode usar diretamente o release publico:
# https://github.com/rustdesk/rustdesk/releases/download/1.4.6/rustdesk-1.4.6-x86_64.msi
# Em producao, prefira hospedar em dominio controlado pela empresa.
# Exemplo URL enterprise: https://downloads.example.com/rustdesk-host.msi
# Exemplo local: C:\deploy\windows-amd64\rustdesk-host.msi
# Fallback suportado: EXE.
# Aliases aceitos: REMOTE_RUSTDESK_UPGRADE_URL / REMOTE_RUSTDESK_UPGRADE_SHA256 / REMOTE_RUSTDESK_UPGRADE_SILENT_ARGS
REMOTE_RUSTDESK_INSTALLER_URL=https://github.com/rustdesk/rustdesk/releases/download/1.4.6/rustdesk-1.4.6-x86_64.msi
REMOTE_RUSTDESK_INSTALLER_SHA256=

# Deixe vazio para usar o default inteligente:
# - MSI: /qn /norestart
# - EXE: /S
REMOTE_RUSTDESK_INSTALL_ARGS=
