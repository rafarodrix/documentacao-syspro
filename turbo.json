{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "test:api": {
      "dependsOn": ["test"],
      "outputs": ["coverage/**"]
    },
    "test:web": {
      "dependsOn": ["test"],
      "outputs": ["coverage/**"]
    },
    "test:packages": {
      "dependsOn": ["test"],
      "outputs": ["coverage/**"]
    }
  }
}
