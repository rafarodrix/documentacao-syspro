{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "allowJs": false,
    "paths": {
      "@dosc-syspro/config": ["../config/src/index.ts"],
      "@dosc-syspro/config/*": ["../config/src/*"],
      "@dosc-syspro/shared": ["../shared/src/index.ts"],
      "@dosc-syspro/shared/*": ["../shared/src/*"],
      "@dosc-syspro/remote-domain": ["../remote-domain/src/index.ts"],
      "@dosc-syspro/remote-domain/contracts": ["../remote-domain/src/remote-domain.contracts.ts"],
      "@dosc-syspro/remote-domain/errors": ["../remote-domain/src/errors.ts"],
      "@dosc-syspro/remote-domain/ports": ["../remote-domain/src/remote-domain.port.ts"],
      "@dosc-syspro/remote-domain/*": ["../remote-domain/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
