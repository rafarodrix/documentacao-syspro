{
    "name":  "@dosc-syspro/database",
    "private":  true,
    "version":  "0.0.0",
    "exports":  {
                    ".":  "./src/index.ts"
                },
    "scripts":  {
                    "db:validate":  "dotenv -e ../../apps/api/.env prisma validate --schema ./prisma/schema.prisma",
                    "db:generate":  "dotenv -e ../../apps/api/.env prisma generate --schema ./prisma/schema.prisma",
                    "db:migrate":  "dotenv -e ../../apps/api/.env prisma migrate dev --schema ./prisma/schema.prisma",
                    "db:deploy":  "dotenv -e ../../apps/api/.env prisma migrate deploy --schema ./prisma/schema.prisma",
                    "db:permissions:audit-legacy": "dotenv -e ../../apps/api/.env node ./scripts/audit-legacy-permissions.mjs",
                    "db:permissions:sanitize-legacy": "dotenv -e ../../apps/api/.env node ./scripts/sanitize-legacy-permissions.mjs",
                    "db:seed:companies":  "dotenv -e ../../apps/api/.env node ./prisma/seed-companies.mjs",
                    "db:seed:remote":  "dotenv -e ../../apps/api/.env node ./prisma/seed-remote-hosts.mjs"
                },
    "devDependencies":  {
                            "dotenv-cli":  "^11.0.0",
                            "prisma":  "^7.8.0"
                        }
}
