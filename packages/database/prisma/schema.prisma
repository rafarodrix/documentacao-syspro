  company       Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  connectionId  String?
  connection    IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  connectionKey String                 @default("env:default")

  chatwootMessageId      String
  chatwootConversationId String
  evolutionMessageId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([connectionKey, chatwootMessageId])
  @@unique([connectionKey, evolutionMessageId])
  @@index([companyId])
  @@index([connectionId])
  @@index([connectionKey])
  @@index([chatwootConversationId])
  @@index([evolutionMessageId])
}

model IntegrationWebhookDedup {
  id              String   @id
  provider        String
  providerEventId String
  instanceId      String?
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@unique([provider, providerEventId])
  @@index([provider, createdAt])
  @@index([expiresAt])
  @@map("integration_webhook_dedup")
}

model IntegrationConnection {
  id String @id @default(cuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name   String
  status IntegrationConnectionStatus @default(ACTIVE)

  evolutionApiUrl                 String
  evolutionApiKeyEncrypted        String
  evolutionInstance               String
  evolutionInstanceId             String?
  evolutionWebhookSecretEncrypted String?

  chatwootUrl                    String
  chatwootApiTokenEncrypted      String
  chatwootAccountId              String
  chatwootInboxId                String?
  chatwootInboxIdentifier        String?
  chatwootWebhookSecretEncrypted String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationLinks ConversationLink[]
  messageLinks      MessageLink[]

  @@unique([companyId, name])
  @@index([status, companyId])
  @@index([evolutionInstance])
  @@index([evolutionInstanceId])
  @@map("integration_connection")
}

model AgentDevice {
  id             String  @id @default(cuid())
  deviceId       String  @unique
  agentInstanceId String? @unique
  credentialId    String? @unique
  hostname       String?
  os             String?
  identitySource String?
  agentVersion   String?

  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  remoteHostId   String?    @unique
  remoteHost     RemoteHost? @relation(fields: [remoteHostId], references: [id], onDelete: SetNull)

  firstSeenAt       DateTime  @default(now())
  lastHeartbeatAt   DateTime?
  lastRegisteredAt  DateTime?

  @@index([deviceId])
  @@index([agentInstanceId])
  @@index([credentialId])
  @@index([lastHeartbeatAt])
  @@index([companyId])
  @@index([companyId, lastHeartbeatAt])
  @@index([remoteHostId])
  @@map("agent_device")
}

model Device {
  id             String   @id @default(cuid())
  deviceId       String   @unique
  hostname       String?
  os             String?
  identitySource String?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  installations AgentInstallation[]

  @@index([lastSeenAt])
  @@map("device")
}

model AgentInstallation {
  id              String   @id @default(cuid())
  deviceRecordId  String
  deviceRecord    Device   @relation(fields: [deviceRecordId], references: [id], onDelete: Cascade)
  agentInstanceId String   @unique
  credentialId    String   @unique
  agentVersion    String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  firstSeenAt      DateTime  @default(now())
  lastHeartbeatAt  DateTime?
  lastRegisteredAt DateTime?
  installedAt      DateTime  @default(now())
  supersededAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  capabilities AgentCapability[]

  @@index([deviceRecordId])
  @@index([companyId])
  @@index([lastHeartbeatAt])
  @@index([supersededAt])
  @@index([companyId, lastHeartbeatAt])
  @@index([deviceRecordId, supersededAt])
  @@map("agent_installation")
}

model AgentCapability {
  id             String               @id @default(cuid())
  installationId String
  installation   AgentInstallation    @relation(fields: [installationId], references: [id], onDelete: Cascade)
  kind           AgentCapabilityKind
  status         AgentCapabilityStatus @default(PENDING)
  externalId     String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  remoteHostId String?     @unique
  remoteHost   RemoteHost? @relation(fields: [remoteHostId], references: [id], onDelete: SetNull)

  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime?
  lastSyncAt       DateTime?
  lastErrorAt      DateTime?
  lastErrorMessage String?  @db.Text
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([installationId, kind])
  @@index([kind, status])
  @@index([companyId])
  @@index([externalId])
  @@index([lastSeenAt])
  @@map("agent_capability")
}

model AgentDeviceRevocation {
  id              String   @id @default(cuid())
  deviceId        String   @unique
  hostname        String?
  revokedAt       DateTime @default(now())
  revokedByUserId String?
  reason          String?  @db.Text

  @@index([revokedAt])
  @@map("agent_device_revocation")
}
