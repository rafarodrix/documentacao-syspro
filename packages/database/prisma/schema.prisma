  description String @db.Text

  // Valores EspecÃƒÂ­ficos: USE DECIMAL PARA CÃƒÂLCULOS
  // @db.Decimal(precisÃƒÂ£o, casas_decimais)
  pRedIBS Decimal? @db.Decimal(5, 2) // Permite valores como 100.00 ou 50.55
  pRedCBS Decimal? @db.Decimal(5, 2)

  tipoAliquota String? // Pode ser nulo dependendo da API
  link         String?

  // Indicadores EspecÃƒÂ­ficos
  indTribRegular  Boolean @default(false)
  indCredPresOper Boolean @default(false)
  indEstornoCred  Boolean @default(false)

  // Flags de Documentos
  indNFe  Boolean @default(false)
  indNFCe Boolean @default(false)
  indCTe  Boolean @default(false)
  indCTeOS Boolean @default(false)
  indBPe   Boolean @default(false)
  indNF3e  Boolean @default(false)
  indNFCom Boolean @default(false)
  indNFSe Boolean @default(false)
  indBPeTM Boolean @default(false)
  indBPeTA Boolean @default(false)
  indNFAg  Boolean @default(false)
  indNFSVIA Boolean @default(false)
  indNFABI  Boolean @default(false)
  indNFGas  Boolean @default(false)
  indDERE   Boolean @default(false)

  // Regras monofasicas e anexo legal de referencia
  monofasiaSujeitaRetencao Boolean @default(false)
  monofasiaRetidaAnt       Boolean @default(false)
  monofasiaDiferimento     Boolean @default(false)
  monofasiaPadrao          Boolean @default(false)
  anexo                    String?

  // VigÃƒÂªncia
  publishDate DateTime
  startDate   DateTime
  endDate     DateTime?
  payloadHash String?

  @@index([cstId]) // Index para performance no Join
  @@index([code]) // Index para buscar rapidament pelo cÃƒÂ³digo na emissÃƒÂ£o de NFe
  @@map("tax_classification")
}

model TaxAnexo {
  id String @id @default(cuid())

  // Chave estÃƒÂ¡vel para upsert do registro vindo da API de anexos
  externalKey String @unique

  // Metadados opcionais para facilitar leitura/filtros
  code        String?
  title       String?
  description String? @db.Text
  category    String?

  publishDate DateTime?
  startDate   DateTime?
  endDate     DateTime?

  // Payload completo retornado pela API
  raw Json

  ncmRefs TaxAnexoNcm[]
  ncmMappings TaxNcmClassMap[]

  lastUpdated DateTime @default(now())
  payloadHash String?

  @@index([code])
  @@index([category])
  @@map("tax_anexo")
}

model TaxAnexoNcm {
  id String @id @default(cuid())

  ncm String

  anexoId String
  anexo   TaxAnexo @relation(fields: [anexoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([anexoId, ncm])
  @@index([ncm])
  @@index([anexoId])
  @@map("tax_anexo_ncm")
}

model TaxNcmClassMap {
  id String @id @default(cuid())

  ncm String
  classCode String?
  cstCode String?
  anexoCode String?

  sourceAnexoId String
  sourceAnexo TaxAnexo @relation(fields: [sourceAnexoId], references: [id], onDelete: Cascade)

  startDate DateTime?
  endDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ncm])
  @@index([classCode])
  @@index([cstCode])
  @@index([anexoCode])
  @@index([sourceAnexoId])
  @@unique([ncm, classCode, cstCode, anexoCode, sourceAnexoId])
  @@map("tax_ncm_class_map")
}

model TaxCredPresumido {
  id String @id @default(cuid())

  // Chave estÃ¡vel para upsert do registro vindo da API de crÃ©dito presumido
  externalKey String @unique

  // Metadados opcionais para facilitar leitura/filtros
  code        String?
  title       String?
  description String? @db.Text
  category    String?

  publishDate DateTime?
  startDate   DateTime?
  endDate     DateTime?

  // Payload completo retornado pela API
  raw Json

  lastUpdated DateTime @default(now())
  payloadHash String?

