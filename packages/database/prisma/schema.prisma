datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// ---------------------------------------------------------
// ENUMS
// ---------------------------------------------------------

enum Role {
  DEVELOPER
  ADMIN
  SUPORTE
  CLIENTE_ADMIN
  CLIENTE_USER
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_DOCS
}

enum ContractStatus {
  ACTIVE
  CANCELLED
  SUSPENDED
}

enum CompanySegment {
  AUTO_PECAS
  COMERCIAL
  FARMACIA
  PANIFICACAO
  AGRICOLA
  PETSHOP
  ESQUADRIAS
  MARMORARIA
  ASSISTENCIA
}

enum CompanyContactSource {
  MANUAL
  WHATSAPP
  IMPORT
}

enum CompanyContactStatus {
  PENDING_LINK
  LINKED
  ARCHIVED
}

enum CompanyServerType {
  SYSPRO_SERVER
  IIS
}

enum CompanyServerProtocol {
  HTTP
  HTTPS
}

enum CompanyRemoteConnectionType {
  DDNS_NOIP
  RADMIN_VPN
}

enum TaxRegime {
  SIMPLES_NACIONAL
  SIMPLES_NACIONAL_EXCESSO
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum IndicadorIE {
  CONTRIBUINTE
  ISENTO
  NAO_CONTRIBUINTE
}

enum SefazServiceType {
  NFE
  NFCE
}

enum SefazStatusType {
  ONLINE
  UNSTABLE
  OFFLINE
}

enum TaxSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum RemoteHostStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RemoteDiscoveredHostStatus {
  PENDING_LINK
  LINKED
  IGNORED
}

enum RemoteSessionStatus {
  REQUESTED
  STARTED
  ENDED
  FAILED
  CANCELLED
}

enum RemoteAgentCommandType {
  REAPPLY_ALIAS
  REAPPLY_CONFIG
  UPGRADE_CLIENT
  ROTATE_TOKEN_REQUIRED
}

enum RemoteAgentCommandStatus {
  PENDING
  DELIVERED
  ACKNOWLEDGED
  CANCELLED
  FAILED
}

enum RemoteAddressBookCredentialScope {
  GLOBAL
  COMPANY
}

enum RemoteAddressBookCredentialStatus {
  ACTIVE
  REVOKED
}

enum ConversationChannel {
  WHATSAPP
  EMAIL
  PORTAL
  PHONE
}

enum ConversationStatus {
  NEW
  UNASSIGNED
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  ARCHIVED
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ConversationEntryPoint {
  INBOUND
  OUTBOUND
  CAMPAIGN
  SYSTEM
}

enum ConversationParticipantKind {
  COMPANY_CONTACT
  USER
  EXTERNAL
}

enum ConversationMessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum ConversationMessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  SYSTEM_EVENT
}

enum ConversationMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationAssignmentStatus {
  ACTIVE
  TRANSFERRED
  RELEASED
}

enum ConversationAssignmentType {
  AUTO
  MANUAL
  TRANSFER
}

enum ConversationQueueKey {
  new
  unassigned
  in_progress
  waiting_customer
  resolved
  archived
}

// ---------------------------------------------------------
// MODELOS PRINCIPAIS 
// ---------------------------------------------------------

model Company {
  id String @id @default(cuid())

  // DADOS PRINCIPAIS
  cnpj         String        @unique
  razaoSocial  String
  nomeFantasia String?
  segment      CompanySegment?
  status       CompanyStatus @default(ACTIVE)
  logoUrl      String?
  serverType   CompanyServerType @default(SYSPRO_SERVER)
  serverPort   Int @default(1234)
  serverHost   String @default("localhost")
  serverProtocol CompanyServerProtocol @default(HTTP)
  iisIsapiPath String? @default("SYSPROSERVERISAPI.DLL")
  installationDirectory String?
  remoteConnectionType CompanyRemoteConnectionType?
  remoteConnectionDetails String?
  remoteConnections Json?

  // HIERARQUIA
  parentCompanyId String?
  parentCompany   Company?  @relation("BranchHierarchy", fields: [parentCompanyId], references: [id])
  branches        Company[] @relation("BranchHierarchy")

  // DADOS FISCAIS
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  indicadorIE        IndicadorIE @default(NAO_CONTRIBUINTE)
  regimeTributario   TaxRegime?
  cnae               String?
  codSuframa         String?
  dataFundacao       DateTime?

  // CONTATO
  emailContato    String?
  emailFinanceiro String?
  telefone        String?
  whatsapp        String?
  website         String?

  // ENDEREÃƒâ€¡O
  addresses Address[]

  // RELAÃƒâ€¡Ãƒâ€¢ES
  accountingFirmId  String?
  accountingFirm    Company?     @relation("AccountantClient", fields: [accountingFirmId], references: [id])
  accountingClients Company[]    @relation("AccountantClient")
  contracts         Contract[]
  memberships       Membership[]
  contacts          CompanyContact[]
  userContactLinks  UserContactLink[]
  conversations     Conversation[]
  remoteHosts       RemoteHost[]
  remoteHostSysproUpdates RemoteHostSysproUpdate[]
  remoteSessions    RemoteSession[]
  remoteAddressBookCredentials RemoteAddressBookCredential[]
  ticketEmails      CompanyTicketEmail[]

  // AUDITORIA
  observacoes String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([razaoSocial])
  @@index([cnpj])
  @@map("company")
}

model CompanyContact {
  id String @id @default(cuid())

  companyId String?
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String
  email String?
  phone String?
  whatsapp String?
  notes String? @db.Text
  isPrimary Boolean @default(false)
  source CompanyContactSource @default(MANUAL)
  status CompanyContactStatus @default(LINKED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]
  authoredConversationMessages ConversationMessage[] @relation("ConversationMessageAuthorContact")
  userLinks UserContactLink[]

  @@index([companyId, status])
  @@index([whatsapp])
  @@map("company_contact")
}

model CompanyTicketEmail {
  id String @id @default(cuid())

  companyId String
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email String
  label String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, email])
  @@index([companyId, isActive])
  @@index([email])
  @@map("company_ticket_email")
}

model Address {
  id               String  @id @default(cuid())
  description      String? // Ex: "Sede", "DepÃƒÂ³sito", "Faturamento"
  cep              String
  logradouro       String
  numero           String
  complemento      String?
  bairro           String
  cidade           String
  estado           String
  pais             String  @default("BR")
  codigoIbgeCidade String?
  codigoIbgeEstado String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("address")
}

// AtualizaÃƒÂ§ÃƒÂ£o no seu DocumentoConfig para vincular ÃƒÂ  empresa
// model DocumentoConfig {
//   ... campos atuais ...
//   companyId String
//   company   Company @relation(fields: [companyId], references: [id])
// }

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  image String?

  // --- SEGURANÃƒâ€¡A E AUTH ---
  // Se usar login por senha (alÃƒÂ©m de OAuth), considere adicionar:
  // passwordHash String? 
  emailVerified  Boolean   @default(false)
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?

  // --- DADOS PROFISSIONAIS ---
  jobTitle String?
  phone    String?
  cpf      String? @unique

  // --- LOCALIZAÃƒâ€¡ÃƒÆ’O ---
  language String @default("pt-BR")

  // --- PREFERÃƒÅ NCIAS ---
  preferences Json? @default("{}")

  // --- AUDITORIA ---
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // --- SISTEMA ---
  role Role @default(CLIENTE_USER)

  // RELAÃƒâ€¡Ãƒâ€¢ES
  memberships Membership[]
  contactLinks UserContactLink[]
  sessions    Session[]
  accounts    Account[]
  assignedConversations Conversation[] @relation("ConversationAssignedUser")
  resolvedConversations Conversation[] @relation("ConversationResolvedByUser")
  authoredConversationMessages ConversationMessage[] @relation("ConversationMessageAuthorUser")
  conversationAssignments ConversationAssignment[] @relation("ConversationAssignmentAssignedUser")
  assignedConversationTransfers ConversationAssignment[] @relation("ConversationAssignmentAssignedByUser")
  transferredConversationAssignments ConversationAssignment[] @relation("ConversationAssignmentTransferFromUser")
  requestedRemoteSessions RemoteSession[] @relation("RemoteSessionRequestedBy")
  startedRemoteSessions   RemoteSession[] @relation("RemoteSessionStartedBy")
  createdRemoteAddressBookCredentials RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialCreatedBy")
  rotatedRemoteAddressBookCredentials RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialRotatedBy")
  revokedRemoteAddressBookCredentials RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialRevokedBy")

  // ÃƒÂNDICES PARA PERFORMANCE
  @@index([name])
  @@index([role])
  @@index([isActive])
  @@index([cpf])
  @@map("user")
}

model UserContactLink {
  id String @id @default(cuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId String
  contact CompanyContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([contactId])
  @@map("user_contact_link")
}

// RelaÃƒÂ§ÃƒÂ£o entre UsuÃƒÂ¡rio e Empresa (Tabela PivÃƒÂ´)
model Membership {
  id String @id @default(cuid())

  // O Cargo ESPECÃƒÂFICO nesta empresa
  role Role @default(CLIENTE_USER)

  // Chaves Estrangeiras
  userId    String
  companyId String

  // Relacionamentos
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Metadados
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Regra: Um usuÃƒÂ¡rio nÃƒÂ£o pode ter 2 cargos na MESMA empresa
  @@unique([userId, companyId])
  // ÃƒÂndices para performance
  @@index([userId])
  @@index([companyId])
  @@map("membership")
}

// ---------------------------------------------------------
// MODELOS DE AUTENTICAÃƒâ€¡ÃƒÆ’O E OUTROS
// ---------------------------------------------------------

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Contract {
  id String @id @default(cuid())

  // --- DADOS FINANCEIROS (Use Decimal para dinheiro/porcentagem precisa) ---
  percentage     Decimal @db.Decimal(7, 4) // Ex: 10.1234
  minimumWage    Decimal @db.Decimal(10, 2) // Ex: 1412.00
  taxRate        Decimal @default(0) @db.Decimal(5, 2)
  programmerRate Decimal @default(0) @db.Decimal(10, 2)

  // Opcional: Valor total calculado do contrato (cache)
  totalValue Decimal? @db.Decimal(12, 2)
  contractNumber String?
  notes          String?  @db.Text

  // --- VIGÃƒÅ NCIA ---
  startDate DateTime  @default(now())
  endDate   DateTime? // Se nulo, ÃƒÂ© indeterminado

  // --- ESTADO ---
  status ContractStatus @default(ACTIVE)

  // --- RELACIONAMENTOS ---
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contract")
}

model RemoteHost {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String
  environment String?
  provider String?
  description String? @db.Text
  notes String? @db.Text
  agentExternalId String?
  installToken String? @unique
  agentTokenHash String? @unique
  machineName String?
  agentVersion String?
  serviceStatus String?
  status RemoteHostStatus @default(ACTIVE)
  lastHeartbeatAt DateTime?
  lastHeartbeatSuccessAt DateTime?
  lastHeartbeatErrorAt DateTime?
  lastHeartbeatErrorMessage String? @db.Text
  lastKnownIp String?
  lastRegisterAt DateTime?
  lastRegisterSource String?
  agentTokenIssuedAt DateTime?
  agentTokenLastUsedAt DateTime?
  lastKnownRustDeskAlias String?
  lastKnownRustDeskVersion String?
  lastKnownRustDeskServerHost String?
  lastKnownRustDeskApiHost String?
  lastKnownRustDeskPublicKeyHash String?
  lastRustDeskConfigSyncAt DateTime?
  lastSystemSnapshot Json?
  lastSystemSnapshotAt DateTime?
  lastNetworkSnapshot Json?
  lastNetworkSnapshotAt DateTime?
  lastSoftwareSnapshot Json?
  lastSoftwareSnapshotAt DateTime?
  lastAgentMetrics Json?
  lastAgentMetricsAt DateTime?
  lastHardwareIdentity Json?
  lastHardwareIdentityAt DateTime?
  lastDiskSnapshot Json?
  lastDiskSnapshotAt DateTime?
  lastSysproProcessSnapshot Json?
  lastSysproProcessSnapshotAt DateTime?
  lastWindowsUpdateStatus Json?
  lastWindowsUpdateStatusAt DateTime?
  lastRebootPending Boolean?
  lastRebootPendingAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions RemoteSession[]
  sysproUpdates RemoteHostSysproUpdate[]
  discoveryRecord RemoteDiscoveredHost?
  agentCommands RemoteAgentCommand[]

  @@index([companyId, status])
  @@index([agentExternalId])
  @@index([installToken])
  @@index([agentTokenHash])
  @@index([lastHeartbeatSuccessAt])
  @@index([lastRustDeskConfigSyncAt])
  @@map("remote_host")
}

model RemoteAgentCommand {
  id String @id @default(cuid())

  hostId String
  host RemoteHost @relation(fields: [hostId], references: [id], onDelete: Cascade)

  type RemoteAgentCommandType
  status RemoteAgentCommandStatus @default(PENDING)
  payload Json?
  reason String? @db.Text
  attemptCount Int @default(0)
  resultMessage String? @db.Text
  resultPayload Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deliveredAt DateTime?
  executedAt DateTime?
  failedAt DateTime?

  @@index([hostId, status, createdAt])
  @@index([hostId, type, status])
  @@map("remote_agent_command")
}

model RemoteAddressBookCredential {
  id String @id @default(cuid())

  label String
  integrationKey String
  scope RemoteAddressBookCredentialScope @default(GLOBAL)
  status RemoteAddressBookCredentialStatus @default(ACTIVE)
  companyId String?
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  tokenHash String @unique
  tokenPreview String
  expiresAt DateTime?
  lastUsedAt DateTime?
  revokedAt DateTime?

  rotatedFromId String?
  rotatedFrom RemoteAddressBookCredential? @relation("RemoteAddressBookCredentialRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  rotations RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialRotation")

  createdByUserId String?
  createdByUser User? @relation("RemoteAddressBookCredentialCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rotatedByUserId String?
  rotatedByUser User? @relation("RemoteAddressBookCredentialRotatedBy", fields: [rotatedByUserId], references: [id], onDelete: SetNull)
  revokedByUserId String?
  revokedByUser User? @relation("RemoteAddressBookCredentialRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scope, companyId])
  @@index([integrationKey, status])
  @@index([expiresAt])
  @@map("remote_address_book_credential")
}

model RemoteDiscoveredHost {
  id String @id @default(cuid())

  linkedHostId String? @unique
  linkedHost   RemoteHost? @relation(fields: [linkedHostId], references: [id], onDelete: SetNull)

  machineName String?
  agentExternalId String?
  agentVersion String?
  provider String?
  environment String?
  description String? @db.Text
  serviceStatus String?
  status RemoteDiscoveredHostStatus @default(PENDING_LINK)
  installationsSnapshot Json?
  firstSeenAt DateTime @default(now())
  lastHeartbeatAt DateTime?
  linkedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([agentExternalId])
  @@index([machineName])
  @@map("remote_discovered_host")
}

model RemoteHostSysproUpdate {
  id String @id @default(cuid())

  hostId String
  host   RemoteHost @relation(fields: [hostId], references: [id], onDelete: Cascade)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  companyLabel String
  path String
  lastFileWriteAt DateTime?
  isServerHost Boolean?
  hasClientFolder Boolean?
  hasDllFolder Boolean?
  firebirdVersion String?
  firebirdPath String?
  lastHeartbeatAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hostId, companyLabel, path])
  @@index([hostId, lastHeartbeatAt])
  @@index([companyId])
  @@map("remote_host_syspro_update")
}

model RemoteSession {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId String?
  ticketNumber String?

  hostId String
  host   RemoteHost @relation(fields: [hostId], references: [id], onDelete: Cascade)

  requestedByUserId String
  requestedByUser   User @relation("RemoteSessionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)

  startedByUserId String?
  startedByUser   User? @relation("RemoteSessionStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)

  status RemoteSessionStatus @default(REQUESTED)
  expiresAt DateTime?
  startedAt DateTime?
  endedAt DateTime?
  reason String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, ticketNumber])
  @@index([hostId, status])
  @@index([requestedByUserId])
  @@map("remote_session")
}

model Conversation {
  id String @id @default(cuid())

  channel ConversationChannel
  status ConversationStatus @default(NEW)
  priority ConversationPriority @default(NORMAL)
  entryPoint ConversationEntryPoint @default(INBOUND)

  companyId String?
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  companyContactId String?
  companyContact CompanyContact? @relation(fields: [companyContactId], references: [id], onDelete: SetNull)

  assignedUserId String?
  assignedUser User? @relation("ConversationAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  resolvedByUserId String?
  resolvedByUser User? @relation("ConversationResolvedByUser", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  ticketId String?
  ticketNumber String?
  subject String?
  externalThreadId String?
  connectionId String?

  contactPhoneSnapshot String?
  contactWhatsappSnapshot String?
  contactNameSnapshot String?

  lastMessagePreview String? @db.Text
  lastMessageAt DateTime?
  lastInboundAt DateTime?
  lastOutboundAt DateTime?
  closedAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ConversationMessage[]
  assignments ConversationAssignment[]
  queueEvents ConversationQueueEvent[]

  @@index([channel, status])
  @@index([companyId, status])
  @@index([companyContactId, status])
  @@index([assignedUserId, status])
  @@index([ticketNumber])
  @@index([lastMessageAt])
  @@map("conversation")
}

model ConversationMessage {
  id String @id @default(cuid())

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction ConversationMessageDirection
  type ConversationMessageType
  authorKind ConversationParticipantKind

  authorUserId String?
  authorUser User? @relation("ConversationMessageAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)

  authorContactId String?
  authorContact CompanyContact? @relation("ConversationMessageAuthorContact", fields: [authorContactId], references: [id], onDelete: SetNull)

  externalMessageId String?

  replyToMessageId String?
  replyToMessage ConversationMessage? @relation("ConversationMessageReplyTo", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies ConversationMessage[] @relation("ConversationMessageReplyTo")

  quotedExternalMessageId String?
  body String? @db.Text
  mediaUrl String?
  storageKey String?
  mediaMimeType String?
  fileSize Int?
  checksum String?

  status ConversationMessageStatus @default(PENDING)
  providerStatus String?
  providerError String? @db.Text
  retryCount Int @default(0)
  metadata Json?

  sentAt DateTime?
  deliveredAt DateTime?
  readAt DateTime?
  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([externalMessageId])
  @@index([authorUserId])
  @@index([authorContactId])
  @@map("conversation_message")
}

model ConversationQueueEvent {
  id String @id @default(cuid())

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  queueKey ConversationQueueKey
  enteredAt DateTime @default(now())
  leftAt DateTime?
  position Int?
  assignedTeam String?
  slaDeadlineAt DateTime?
  breachedAt DateTime?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([conversationId, enteredAt])
  @@index([queueKey, leftAt])
  @@index([slaDeadlineAt])
  @@map("conversation_queue_event")
}

model ConversationAssignment {
  id String @id @default(cuid())

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  assignedUserId String
  assignedUser User @relation("ConversationAssignmentAssignedUser", fields: [assignedUserId], references: [id], onDelete: Restrict)

  assignedByUserId String?
  assignedByUser User? @relation("ConversationAssignmentAssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  transferFromUserId String?
  transferFromUser User? @relation("ConversationAssignmentTransferFromUser", fields: [transferFromUserId], references: [id], onDelete: SetNull)

  assignmentType ConversationAssignmentType @default(MANUAL)
  status ConversationAssignmentStatus @default(ACTIVE)
  reason String? @db.Text
  startedAt DateTime @default(now())
  acceptedAt DateTime?
  declinedAt DateTime?
  endedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, status])
  @@index([assignedUserId, status])
  @@index([assignedByUserId])
  @@index([transferFromUserId])
  @@map("conversation_assignment")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// cst
model TaxCST {
  id          String @id @default(cuid())
  cst         String @unique // Ex: "01", "50"
  description String @db.Text // DescriÃƒÂ§ÃƒÂµes fiscais podem ser longas

  // Indicadores (Flags do nÃƒÂ­vel CST)
  indIBSCBS         Boolean @default(false)
  indRedBC          Boolean @default(false)
  indRedAliq        Boolean @default(false)
  indTransfCred     Boolean @default(false)
  indDif            Boolean @default(false)
  indAjusteCompet   Boolean @default(false)
  indIBSCBSMono     Boolean @default(false)
  indCredPresIBSZFM Boolean @default(false)

  // VigÃƒÂªncia do CST
  publishDate DateTime
  startDate   DateTime
  endDate     DateTime?

  // Relacionamento
  classifications TaxClassification[]

  lastUpdated DateTime @default(now())
  payloadHash String?

  @@map("tax_cst")
}

// cClassTrib
model TaxClassification {
  id String @id @default(cuid())

  // Chave Estrangeira para o CST
  cstId String
  cst   TaxCST @relation(fields: [cstId], references: [id], onDelete: Cascade)

