datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// ---------------------------------------------------------
// ENUMS
// ---------------------------------------------------------

enum Role {
  DEVELOPER
  ADMIN
  SUPORTE
  CLIENTE_ADMIN
  CLIENTE_USER
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_DOCS
}

enum ContractStatus {
  ACTIVE
  CANCELLED
  SUSPENDED
}

enum CompanySegment {
  AUTO_PECAS
  COMERCIAL
  FARMACIA
  PANIFICACAO
  AGRICOLA
  PETSHOP
  ESQUADRIAS
  MARMORARIA
  ASSISTENCIA
}

enum CompanyContactSource {
  MANUAL
  WHATSAPP
  IMPORT
}

enum CompanyContactStatus {
  PENDING_LINK
  LINKED
  ARCHIVED
}

enum CompanyServerType {
  SYSPRO_SERVER
  IIS
}

enum CompanyServerProtocol {
  HTTP
  HTTPS
}

enum CompanyRemoteConnectionType {
  DDNS_NOIP
  RADMIN_VPN
}

enum TaxRegime {
  SIMPLES_NACIONAL
  SIMPLES_NACIONAL_EXCESSO
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum IndicadorIE {
  CONTRIBUINTE
  ISENTO
  NAO_CONTRIBUINTE
}

enum SefazServiceType {
  NFE
  NFCE
  CTE
  MDFE
}

enum SefazStatusType {
  ONLINE
  UNSTABLE
  OFFLINE
}

enum TaxSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum RemoteHostStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RemoteDiscoveredHostStatus {
  PENDING_LINK
  LINKED
  IGNORED
}

enum RemoteSessionStatus {
  REQUESTED
  STARTED
  ENDED
  FAILED
  CANCELLED
}

enum RemoteAgentCommandType {
  REAPPLY_ALIAS
  REAPPLY_CONFIG
  UPGRADE_CLIENT
  ROTATE_TOKEN_REQUIRED
  SERVICE_CONTROL
}

enum RemoteAgentCommandStatus {
  PENDING
  DELIVERED
  ACKNOWLEDGED
  CANCELLED
  FAILED
}

enum RemoteAddressBookCredentialScope {
  GLOBAL
  COMPANY
}

enum RemoteAddressBookCredentialStatus {
  ACTIVE
  REVOKED
}

enum AccessScopeType {
  GLOBAL
  COMPANY
}

enum ConversationChannel {
  WHATSAPP
  EMAIL
  PORTAL
  PHONE
}

enum ConversationStatus {
  NEW
  UNASSIGNED
  TRIAGE
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_INTERNAL
  TESTING
  RESOLVED
  ARCHIVED
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ConversationEntryPoint {
  INBOUND
  OUTBOUND
  CAMPAIGN
  SYSTEM
}

enum ConversationParticipantKind {
  COMPANY_CONTACT
  USER
  EXTERNAL
}

enum ConversationMessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum ConversationMessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  SYSTEM_EVENT
}

enum ConversationMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationAssignmentStatus {
  ACTIVE
  TRANSFERRED
  RELEASED
}

enum ConversationAssignmentType {
  AUTO
  MANUAL
  TRANSFER
}

enum IntegrationConnectionStatus {
  ACTIVE
  INACTIVE
}

enum CrmLeadStage {
  LEAD
  MQL
  SQL
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmLeadSource {
  MANUAL
  WHATSAPP
  REFERRAL
  FORM
  EVENT
  OUTBOUND
  CAMPAIGN
  OTHER
}

enum CrmActivityType {
  NOTE
  CALL
  MEETING
  EMAIL
  WHATSAPP
  SYSTEM_EVENT
}

enum CrmTaskStatus {
  PENDING
  COMPLETED
  CANCELED
}

enum TaskType {
  ROTINA_MENSAL
  TAREFA
}

enum TaskStatus {
  PENDING
  WAITING_CUSTOMER
  RECEIVED
  SENT_TO_ACCOUNTING
  COMPLETED
  OVERDUE
  CANCELED
}

enum TaskRequestChannel {
  WHATSAPP
}

enum TaskRequestStatus {
  SENT
  FAILED
}

enum AgentCapabilityKind {
  REMOTE
  BACKUP
  TUNNEL
  SUPPORT
  DEVICE
}

enum AgentCapabilityStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
  REVOKED
}

// ---------------------------------------------------------
// MODELOS PRINCIPAIS 
// ---------------------------------------------------------

model Company {
  id String @id @default(cuid())

  // DADOS PRINCIPAIS
  cnpj                    String                       @unique
  razaoSocial             String
  nomeFantasia            String?
  searchText              String                       @default("")
  segment                 CompanySegment?
  status                  CompanyStatus                @default(ACTIVE)
  logoUrl                 String?
  serverType              CompanyServerType            @default(SYSPRO_SERVER)
  serverPort              Int                          @default(1234)
  serverHost              String                       @default("localhost")
  serverProtocol          CompanyServerProtocol        @default(HTTP)
  iisIsapiPath            String?                      @default("SYSPROSERVERISAPI.DLL")
  installationDirectory   String?
  remoteConnectionType    CompanyRemoteConnectionType?
  remoteConnectionDetails String?
  remoteConnections       Json?

  // HIERARQUIA
  parentCompanyId String?
  parentCompany   Company?  @relation("BranchHierarchy", fields: [parentCompanyId], references: [id])
  branches        Company[] @relation("BranchHierarchy")

  // DADOS FISCAIS
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  indicadorIE        IndicadorIE @default(NAO_CONTRIBUINTE)
  regimeTributario   TaxRegime?
  cnae               String?
  cnaeDescricao      String?
  cnaesSecundarios   Json?
  codSuframa         String?
  dataFundacao       DateTime?
  naturezaJuridica   String?
  porte              String?
  matrizFilial       String?
  situacaoCadastral  String?
  qsa                Json?

  // CONTATO
  emailContato    String?
  emailFinanceiro String?
  telefone        String?
  whatsapp        String?
  website         String?

  // ENDERECOS
  addresses Address[]

  // RELACIONAMENTOS
  accountingFirmId             String?
  accountingFirm               Company?                      @relation("AccountantClient", fields: [accountingFirmId], references: [id])
  accountingClients            Company[]                     @relation("AccountantClient")
  contracts                    Contract[]
  memberships                  Membership[]
  contactLinks                 CompanyContactCompanyLink[]
  userContactLinks             UserContactLink[]
  tickets                      Ticket[]
  remoteHosts                  RemoteHost[]
  remoteHostSysproUpdates      RemoteHostSysproUpdate[]
  remoteSessions               RemoteSession[]
  remoteAddressBookCredentials RemoteAddressBookCredential[]
  integrationConnections       IntegrationConnection[]
  conversationLinks            ConversationLink[]
  messageLinks                 MessageLink[]
  userAccessProfiles           UserAccessProfile[]
  convertedCrmLeads            CrmLead[]                     @relation("CrmLeadConvertedCompany")
  agentDevices                 AgentDevice[]
  agentInstallations           AgentInstallation[]
  agentCapabilities            AgentCapability[]
  taskConfig                   TaskConfig?
  tasks                        Task[]
  taskRequests                 TaskRequest[]

  // AUDITORIA
  observacoes String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([razaoSocial])
  @@index([cnpj])
  @@map("company")
}

model CompanyContact {
  id String @id @default(cuid())

  name       String
  email      String?
  phone      String?
  whatsapp   String?
  cpf        String?              @unique
  jobTitle   String?
  notes      String?              @db.Text
  searchText String               @default("")
  isPrimary  Boolean              @default(false)
  source     CompanyContactSource @default(MANUAL)
  status     CompanyContactStatus @default(LINKED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets                      Ticket[]
  authoredConversationMessages ConversationMessage[]       @relation("ConversationMessageAuthorContact")
  userLinks                    UserContactLink[]
  users                        User[]
  companyLinks                 CompanyContactCompanyLink[]
  taskClientConfigs               TaskConfig[] @relation("TaskClientContact")
  taskAccountingConfigs           TaskConfig[] @relation("TaskAccountingContact")
  taskRequests                    TaskRequest[]

  @@index([status])
  @@index([whatsapp])
  @@map("company_contact")
}

model CompanyContactCompanyLink {
  id String @id @default(cuid())

  contactId String
  contact   CompanyContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, companyId])
  @@index([companyId])
  @@index([contactId, isPrimary])
  @@map("company_contact_company_link")
}

model Address {
  id               String  @id @default(cuid())
  description      String? // Ex: "Sede", "DepÃƒÂ³sito", "Faturamento"
  cep              String
  logradouro       String
  numero           String
  complemento      String?
  bairro           String
  cidade           String
  estado           String
  pais             String  @default("BR")
  codigoIbgeCidade String?
  codigoIbgeEstado String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("address")
}

// AtualizaÃƒÂ§ÃƒÂ£o no seu DocumentoConfig para vincular ÃƒÂ  empresa
// model DocumentoConfig {
//   ... campos atuais ...
//   companyId String
//   company   Company @relation(fields: [companyId], references: [id])
// }

model User {
  id        String          @id @default(cuid())
  email     String          @unique
  name      String?
  image     String?
  contactId String?
  contact   CompanyContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // --- SEGURANCA E AUTH ---
  emailVerified  Boolean   @default(false)
  isActive       Boolean   @default(true)
  banned         Boolean   @default(false)
  banReason      String?
  banExpires     DateTime?
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?

  // --- LOCALIZACAO ---
  language String @default("pt-BR")

  // --- PREFERENCIAS ---
  preferences Json? @default("{}")

  // --- AUDITORIA ---
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // --- SISTEMA ---
  role Role @default(CLIENTE_USER)

  // RELACOES
  memberships                         Membership[]
  contactLinks                        UserContactLink[]
  sessions                            Session[]
  accounts                            Account[]
  assignedTickets                     Ticket[]                      @relation("TicketAssignedUser")
  resolvedTickets                     Ticket[]                      @relation("TicketResolvedByUser")
  authoredConversationMessages        ConversationMessage[]         @relation("ConversationMessageAuthorUser")
  conversationAssignments             ConversationAssignment[]      @relation("ConversationAssignmentAssignedUser")
  assignedConversationTransfers       ConversationAssignment[]      @relation("ConversationAssignmentAssignedByUser")
  transferredConversationAssignments  ConversationAssignment[]      @relation("ConversationAssignmentTransferFromUser")
  requestedRemoteSessions             RemoteSession[]               @relation("RemoteSessionRequestedBy")
  startedRemoteSessions               RemoteSession[]               @relation("RemoteSessionStartedBy")
  createdRemoteAddressBookCredentials RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialCreatedBy")
  rotatedRemoteAddressBookCredentials RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialRotatedBy")
  revokedRemoteAddressBookCredentials RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialRevokedBy")
  accessProfileAssignments            UserAccessProfile[]           @relation("UserAccessProfileUser")
  assignedAccessProfiles              UserAccessProfile[]           @relation("UserAccessProfileAssignedBy")
  crmOwnedLeads                       CrmLead[]                     @relation("CrmLeadOwner")
  authoredCrmActivities               CrmActivity[]                 @relation("CrmActivityAuthor")
  assignedCrmTasks                    CrmTask[]                     @relation("CrmTaskAssignee")
  assignedTaskConfigs                 TaskConfig[]                  @relation("TaskConfigAssignee")
  requestedTaskRequests               TaskRequest[]                 @relation("TaskRequestRequestedBy")
  authoredTaskHistory                 TaskHistory[]
  assignedTasks                       Task[]                        @relation("TaskAssignee")

  // INDICES PARA PERFORMANCE
  @@index([name])
  @@index([role])
  @@index([isActive])
  @@index([contactId])
  @@map("user")
}

model UserContactLink {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId String
  contact   CompanyContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([contactId])
  @@map("user_contact_link")
}

// RelaÃƒÂ§ÃƒÂ£o entre UsuÃƒÂ¡rio e Empresa (Tabela PivÃƒÂ´)
model Membership {
  id String @id @default(cuid())

  // O Cargo ESPECÃƒÂFICO nesta empresa
  role Role @default(CLIENTE_USER)

  // Chaves Estrangeiras
  userId    String
  companyId String

  // Relacionamentos
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Metadados
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Regra: Um usuário não pode ter 2 cargos na MESMA empresa
  @@unique([userId, companyId])
  // Índices para performance
  @@index([userId])
  @@index([companyId])
  @@map("membership")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  moduleKey   String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accessProfilePermissions AccessProfilePermission[]

  @@index([moduleKey, isActive])
  @@map("permission")
}

model AccessProfile {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions     AccessProfilePermission[]
  userAssignments UserAccessProfile[]

  @@index([isSystem, isActive])
  @@map("access_profile")
}

model AccessProfilePermission {
  id String @id @default(cuid())

  profileId String
  profile   AccessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, permissionId])
  @@index([permissionId])
  @@map("access_profile_permission")
}

model UserAccessProfile {
  id String @id @default(cuid())

  userId String
  user   User   @relation("UserAccessProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  profileId String
  profile   AccessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  scopeType AccessScopeType @default(GLOBAL)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedByUserId String?
  assignedByUser   User?   @relation("UserAccessProfileAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  reason    String?   @db.Text
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, scopeType])
  @@index([profileId, scopeType])
  @@index([companyId])
  @@index([assignedByUserId])
  @@map("user_access_profile")
}

// ---------------------------------------------------------
// MODELOS DE AUTENTICAÃƒâ€¡ÃƒÆ’O E OUTROS
// ---------------------------------------------------------

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Contract {
  id String @id @default(cuid())

  // --- DADOS FINANCEIROS (Use Decimal para dinheiro/porcentagem precisa) ---
  percentage     Decimal @db.Decimal(7, 4) // Ex: 10.1234
  minimumWage    Decimal @db.Decimal(10, 2) // Ex: 1412.00
  taxRate        Decimal @default(0) @db.Decimal(5, 2)
  programmerRate Decimal @default(0) @db.Decimal(10, 2)

  // Opcional: Valor total calculado do contrato (cache)
  totalValue     Decimal? @db.Decimal(12, 2)
  contractNumber String?
  notes          String?  @db.Text

  // --- VIGÃƒÅ NCIA ---
  startDate DateTime  @default(now())
  endDate   DateTime? // Se nulo, ÃƒÂ© indeterminado

  // --- ESTADO ---
  status ContractStatus @default(ACTIVE)

  // --- RELACIONAMENTOS ---
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contract")
}

model RemoteHost {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name                           String
  machineProfile                 String?
  environment                    String?
  provider                       String?
  description                    String?          @db.Text
  notes                          String?          @db.Text
  agentExternalId                String?          @unique
  installToken                   String?          @unique
  agentTokenHash                 String?          @unique
  machineName                    String?
  agentVersion                   String?
  serviceStatus                  String?
  status                         RemoteHostStatus @default(ACTIVE)
  lastHeartbeatAt                DateTime?
  lastHeartbeatSuccessAt         DateTime?
  lastHeartbeatErrorAt           DateTime?
  lastHeartbeatErrorMessage      String?          @db.Text
  lastKnownIp                    String?
  lastRegisterAt                 DateTime?
  lastRegisterSource             String?
  agentTokenIssuedAt             DateTime?
  agentTokenLastUsedAt           DateTime?
  lastKnownRustDeskAlias         String?
  lastKnownRustDeskVersion       String?
  lastKnownRustDeskServerHost    String?
  lastKnownRustDeskApiHost       String?
  lastKnownRustDeskPublicKeyHash String?
  lastRustDeskConfigSyncAt       DateTime?
  lastSystemSnapshot             Json?
  lastSystemSnapshotAt           DateTime?
  lastNetworkSnapshot            Json?
  lastNetworkSnapshotAt          DateTime?
  lastSoftwareSnapshot           Json?
  lastSoftwareSnapshotAt         DateTime?
  lastAgentMetrics               Json?
  lastAgentMetricsAt             DateTime?
  lastHardwareIdentity           Json?
  lastHardwareIdentityAt         DateTime?
  lastDiskSnapshot               Json?
  lastDiskSnapshotAt             DateTime?
  lastSysproProcessSnapshot      Json?
  lastSysproProcessSnapshotAt    DateTime?
  lastSysproVersionSnapshot      Json?
  lastSysproVersionSnapshotAt    DateTime?
  lastWindowsUpdateStatus        Json?
  lastWindowsUpdateStatusAt      DateTime?
  lastAllServicesSnapshot        Json?
  lastAllServicesSnapshotAt      DateTime?
  lastRebootPending              Boolean?
  lastRebootPendingAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions        RemoteSession[]
  sysproUpdates   RemoteHostSysproUpdate[]
  discoveryRecord RemoteDiscoveredHost?
  agentCommands   RemoteAgentCommand[]
  agentDevice     AgentDevice?
  agentCapabilities AgentCapability[]

  @@index([companyId, status])
  @@index([installToken])
  @@index([agentTokenHash])
  @@index([lastHeartbeatSuccessAt])
  @@index([lastRustDeskConfigSyncAt])
  @@map("remote_host")
}

model RemoteAgentCommand {
  id String @id @default(cuid())

  hostId String
  host   RemoteHost @relation(fields: [hostId], references: [id], onDelete: Cascade)

  type          RemoteAgentCommandType
  status        RemoteAgentCommandStatus @default(PENDING)
  payload       Json?
  reason        String?                  @db.Text
  attemptCount  Int                      @default(0)
  resultMessage String?                  @db.Text
  resultPayload Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  deliveredAt   DateTime?
  executedAt    DateTime?
  failedAt      DateTime?

  @@index([hostId, status, createdAt])
  @@index([hostId, type, status])
  @@map("remote_agent_command")
}

model RemoteAddressBookCredential {
  id String @id @default(cuid())

  label          String
  integrationKey String
  scope          RemoteAddressBookCredentialScope  @default(GLOBAL)
  status         RemoteAddressBookCredentialStatus @default(ACTIVE)
  companyId      String?
  company        Company?                          @relation(fields: [companyId], references: [id], onDelete: SetNull)

  tokenHash    String    @unique
  tokenPreview String
  expiresAt    DateTime?
  lastUsedAt   DateTime?
  revokedAt    DateTime?

  rotatedFromId String?
  rotatedFrom   RemoteAddressBookCredential?  @relation("RemoteAddressBookCredentialRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  rotations     RemoteAddressBookCredential[] @relation("RemoteAddressBookCredentialRotation")

  createdByUserId String?
  createdByUser   User?   @relation("RemoteAddressBookCredentialCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rotatedByUserId String?
  rotatedByUser   User?   @relation("RemoteAddressBookCredentialRotatedBy", fields: [rotatedByUserId], references: [id], onDelete: SetNull)
  revokedByUserId String?
  revokedByUser   User?   @relation("RemoteAddressBookCredentialRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scope, companyId])
  @@index([integrationKey, status])
  @@index([expiresAt])
  @@map("remote_address_book_credential")
}

model RemoteDiscoveredHost {
  id String @id @default(cuid())

  linkedHostId String?     @unique
  linkedHost   RemoteHost? @relation(fields: [linkedHostId], references: [id], onDelete: SetNull)

  machineName           String?
  agentExternalId       String?
  agentVersion          String?
  provider              String?
  environment           String?
  description           String?                    @db.Text
  serviceStatus         String?
  status                RemoteDiscoveredHostStatus @default(PENDING_LINK)
  installationsSnapshot Json?
  firstSeenAt           DateTime                   @default(now())
  lastHeartbeatAt       DateTime?
  linkedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([agentExternalId])
  @@index([machineName])
  @@map("remote_discovered_host")
}

model RemoteHostSysproUpdate {
  id String @id @default(cuid())

  hostId String
  host   RemoteHost @relation(fields: [hostId], references: [id], onDelete: Cascade)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  companyLabel    String
  path            String
  lastFileWriteAt DateTime?
  isServerHost    Boolean?
  hasClientFolder Boolean?
  hasDllFolder    Boolean?
  firebirdVersion String?
  firebirdPath    String?
  lastHeartbeatAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hostId, companyLabel, path])
  @@index([hostId, lastHeartbeatAt])
  @@index([companyId])
  @@map("remote_host_syspro_update")
}

model RemoteSession {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ticketId     String?
  ticketNumber String?

  hostId String
  host   RemoteHost @relation(fields: [hostId], references: [id], onDelete: Cascade)

  requestedByUserId String
  requestedByUser   User   @relation("RemoteSessionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)

  startedByUserId String?
  startedByUser   User?   @relation("RemoteSessionStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)

  status    RemoteSessionStatus @default(REQUESTED)
  expiresAt DateTime?
  startedAt DateTime?
  endedAt   DateTime?
  reason    String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

