{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "types": ["node"],
    "allowJs": false,
    "noEmit": true,
    "paths": {
      "@dosc-syspro/database": ["../../../database/src/index.ts"],
      "@dosc-syspro/database/*": ["../../../database/src/*"],
      "@dosc-syspro/tickets-domain": ["../domain/src/index.ts"],
      "@dosc-syspro/tickets-domain/*": ["../domain/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
