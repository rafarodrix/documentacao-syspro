# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# Authentication
BETTER_AUTH_URL="http://localhost:3001/api/auth"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
EXTRA_TRUSTED_ORIGINS="http://localhost:3000"
INTERNAL_API_KEY="replace-with-internal-api-key"

# Email
GMAIL_USER="you@example.com"
GMAIL_PASS="replace-with-app-password"

# Public API
NEXT_PUBLIC_API_URL="https://your-public-api.example.com"

# Remote module
PORTAL_API_BASE_URL="https://your-portal.example.com"
REMOTE_DISCOVERY_TOKEN="replace-with-discovery-token"
REVALIDATE_TOKEN="replace-with-revalidate-token"
PORTAL_API_TOKEN="replace-with-portal-api-token"

# Remote agent upgrade
REMOTE_RUSTDESK_UPGRADE_URL=""
REMOTE_RUSTDESK_UPGRADE_SHA256=""
REMOTE_RUSTDESK_UPGRADE_PACKAGE_TYPE="installer"
REMOTE_RUSTDESK_UPGRADE_SILENT_ARGS="/S"

# Evolution
EVOLUTION_API_URL="https://api.example.com"
EVOLUTION_API_KEY="replace-with-evolution-api-key"
EVOLUTION_INSTANCE="default-instance"
EVOLUTION_INSTANCE_TOKEN=""
EVOLUTION_WEBHOOK_SECRET="replace-with-evolution-webhook-secret"

# Chatwoot
CHATWOOT_URL="https://chat.example.com"
CHATWOOT_API_TOKEN="replace-with-chatwoot-api-token"
CHATWOOT_PLATFORM_API_TOKEN="replace-with-chatwoot-platform-token"
CHATWOOT_ACCOUNT_ID="1"
CHATWOOT_INBOX_ID="1"
CHATWOOT_INBOX_IDENTIFIER=""
CHATWOOT_WEBHOOK_SECRET="replace-with-chatwoot-webhook-secret"
CHATWOOT_WEBHOOK_MAX_SKEW_SECONDS="300"

# Integration hardening
INTEGRATION_WEBHOOK_DEDUP_TTL_SECONDS="86400"
INTEGRATION_CONFIG_ENCRYPTION_KEY="replace-with-strong-32-plus-char-key"
